APP_NAME=CGM API
APP_VERSION=1.0.0

# PostgreSQL credentials (used by the glucodb container)
POSTGRES_USER=glucouser
POSTGRES_PASSWORD=glucopassword
POSTGRES_DB=glucodb

# Use the Docker service name "glucodb" as the host when running via docker compose
DATABASE_URL=postgresql://glucouser:glucopassword@glucodb:5432/glucodb

NIGHTSCOUT_URL=
NIGHTSCOUT_SECRET=secret

# JWT signing secret — use a long random string in production
SECRET_KEY=change-me-to-a-long-random-secret

API_KEY=secret123
ANTHROPIC_API_KEY=sk-ant-placeholder
OPENAI_API_KEY=sk-placeholder
